<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>AutoSentinel | Vehicle Review Sentiment Analysis</title>
  <!-- Google Fonts & simple icons (Font Awesome) -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(145deg, #f1f5f9 0%, #e6edf4 100%);
      font-family: 'Inter', sans-serif;
      padding: 2rem 1.5rem;
      color: #0a1e2f;
      min-height: 100vh;
    }

    /* main container */
    .app-container {
      max-width: 1400px;
      margin: 0 auto;
    }

    /* header section with flair */
    .hero {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .hero h1 {
      font-size: 2.6rem;
      font-weight: 700;
      background: linear-gradient(135deg, #1e3c5c, #2b5a7a);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: -0.02em;
      display: inline-flex;
      align-items: center;
      gap: 12px;
    }

    .hero h1 i {
      background: none;
      color: #2b5a7a;
      font-size: 2.4rem;
      background-clip: unset;
      -webkit-background-clip: unset;
    }

    .hero .tagline {
      color: #2c4b6e;
      font-weight: 500;
      margin-top: 10px;
      font-size: 1.1rem;
      background: rgba(255,255,240,0.6);
      display: inline-block;
      padding: 0.4rem 1.2rem;
      border-radius: 60px;
      backdrop-filter: blur(2px);
    }

    /* double card layout: input + analysis */
    .dashboard {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-bottom: 2rem;
    }

    @media (max-width: 880px) {
      .dashboard {
        grid-template-columns: 1fr;
        gap: 1.8rem;
      }
      body {
        padding: 1.2rem;
      }
      .hero h1 {
        font-size: 2rem;
      }
    }

    /* card style */
    .card {
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(0px);
      border-radius: 2rem;
      box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.1), 0 1px 2px rgba(0,0,0,0.02);
      padding: 1.8rem 2rem;
      transition: transform 0.2s ease;
      border: 1px solid rgba(255,255,255,0.6);
    }

    .card:hover {
      transform: translateY(-3px);
    }

    .card-title {
      font-size: 1.6rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
      border-bottom: 2px solid #e2e8f0;
      padding-bottom: 0.8rem;
      margin-bottom: 1.5rem;
      color: #0f2c3f;
    }

    .card-title i {
      color: #3b82f6;
      font-size: 1.5rem;
    }

    /* textarea */
    .review-input {
      width: 100%;
      border: 2px solid #e2edf2;
      border-radius: 1.5rem;
      padding: 1rem 1.4rem;
      font-size: 1rem;
      font-family: 'Inter', monospace;
      background: #fefefe;
      resize: vertical;
      transition: all 0.2s;
      outline: none;
      line-height: 1.5;
    }

    .review-input:focus {
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59,130,246,0.2);
    }

    /* character counter */
    .char-counter {
      text-align: right;
      font-size: 0.75rem;
      color: #5f7d9c;
      margin-top: 8px;
      margin-bottom: 1rem;
    }

    /* buttons */
    .btn-group {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin: 1rem 0 0.5rem;
    }

    .btn-primary {
      background: linear-gradient(100deg, #1e4b6e, #256f8f);
      border: none;
      color: white;
      font-weight: 600;
      padding: 0.8rem 1.8rem;
      border-radius: 2rem;
      cursor: pointer;
      font-size: 0.95rem;
      transition: 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      box-shadow: 0 5px 12px rgba(0, 50, 70, 0.2);
    }

    .btn-primary:hover {
      background: linear-gradient(100deg, #143d58, #1c5a78);
      transform: scale(0.97);
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .btn-secondary {
      background: #f1f5f9;
      border: 1px solid #cbd5e1;
      color: #1e3a5f;
      font-weight: 500;
      padding: 0.8rem 1.6rem;
      border-radius: 2rem;
      cursor: pointer;
      transition: 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .btn-secondary:hover {
      background: #e6edf4;
      border-color: #94a3b8;
    }

    /* example chips */
    .example-section {
      margin-top: 1.5rem;
    }

    .example-label {
      font-size: 0.8rem;
      font-weight: 600;
      color: #3f6b8c;
      margin-bottom: 8px;
      letter-spacing: 0.3px;
    }

    .example-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .chip {
      background: #eef3fc;
      padding: 0.4rem 1rem;
      border-radius: 30px;
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.15s;
      font-weight: 500;
      color: #1f4e6e;
      border: 1px solid #cfe3f0;
    }

    .chip:hover {
      background: #d9e9f5;
      transform: translateY(-1px);
      border-color: #3b82f6;
    }

    /* result section */
    .result-card {
      background: #ffffffdd;
    }

    .sentiment-badge {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: #f8fafc;
      padding: 0.8rem 1.4rem;
      border-radius: 60px;
      margin-bottom: 1.5rem;
      font-weight: 700;
      font-size: 1.2rem;
      box-shadow: inset 0 0 0 1px #eef2f6;
    }

    .score-bar-container {
      background: #edf2f7;
      border-radius: 40px;
      height: 14px;
      width: 100%;
      margin: 1rem 0 0.6rem;
      overflow: hidden;
    }

    .score-fill {
      width: 0%;
      height: 100%;
      border-radius: 40px;
      transition: width 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    }

    .positive-fill {
      background: linear-gradient(90deg, #22c55e, #2dd4bf);
    }
    .negative-fill {
      background: linear-gradient(90deg, #ef4444, #f97316);
    }
    .neutral-fill {
      background: linear-gradient(90deg, #facc15, #eab308);
    }

    .metrics {
      margin-top: 1.5rem;
    }

    .metric-item {
      display: flex;
      justify-content: space-between;
      margin-bottom: 12px;
      font-size: 0.9rem;
      border-bottom: 1px dashed #e2edf2;
      padding-bottom: 6px;
    }

    .confidence-highlight {
      font-weight: 700;
      color: #0f3b5c;
    }

    .review-text-analysis {
      background: #f1f6fc;
      margin-top: 1.4rem;
      padding: 1rem;
      border-radius: 1.2rem;
      border-left: 5px solid #3b82f6;
      font-style: italic;
      font-size: 0.9rem;
      word-break: break-word;
    }

    .loader {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 3px solid rgba(255,255,255,0.5);
      border-radius: 50%;
      border-top-color: white;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    footer {
      text-align: center;
      margin-top: 2.5rem;
      font-size: 0.75rem;
      color: #59748f;
      border-top: 1px solid #cbdbe0;
      padding-top: 1.8rem;
    }

    i.fa, i.far, i.fas {
      pointer-events: none;
    }
  </style>
</head>
<body>
<div class="app-container">
  <div class="hero">
    <h1>
      <i class="fas fa-car-side"></i> 
      AutoSentinel
      <i class="fas fa-chart-line"></i>
    </h1>
    <div class="tagline">
      <i class="fas fa-microphone-alt"></i> Decode driver emotions • Real‑time vehicle review sentiment
    </div>
  </div>

  <div class="dashboard">
    <!-- LEFT: Review input panel -->
    <div class="card">
      <div class="card-title">
        <i class="fas fa-pen-alt"></i> 
        <span>Vehicle Review</span>
      </div>
      <textarea id="reviewText" class="review-input" rows="6" placeholder="Example: 'The torque on this electric SUV is insane! Smooth handling, premium interior. My best purchase ever.' or 'The infotainment lags constantly, plus cheap plastics. Regret buying this sedan...'"></textarea>
      <div class="char-counter">
        <span id="charCount">0</span> characters | <i class="far fa-comment-dots"></i> share your driving experience
      </div>
      <div class="btn-group">
        <button id="analyzeBtn" class="btn-primary"><i class="fas fa-brain"></i> Analyze Sentiment</button>
        <button id="clearBtn" class="btn-secondary"><i class="fas fa-eraser"></i> Clear</button>
      </div>
      
      <div class="example-section">
        <div class="example-label"><i class="fas fa-lightbulb"></i> Try quick examples</div>
        <div class="example-chips">
          <span class="chip" data-example="The acceleration is electrifying and the cabin is whisper quiet. Love this hybrid!">🚗 Positive: Sporty hybrid</span>
          <span class="chip" data-example="Transmission jerks at low speeds, uncomfortable seats. Massive disappointment.">⚠️ Negative: Transmission issues</span>
          <span class="chip" data-example="Average fuel economy, nothing special, but it gets me from A to B. Okay vehicle.">⚖️ Neutral: Just fine</span>
          <span class="chip" data-example="The Tesla Model Y has impressive range and autopilot is next level. Truly a game changer!">🔋 EV enthusiast</span>
        </div>
      </div>
    </div>

    <!-- RIGHT: Sentiment Analysis & Results -->
    <div class="card result-card">
      <div class="card-title">
        <i class="fas fa-chart-pie"></i>
        <span>Sentiment Intelligence</span>
      </div>
      
      <div id="resultArea">
        <!-- default state: waiting for analysis -->
        <div style="text-align: center; padding: 1rem 0 2rem 0; color: #5e7e9e;">
          <i class="fas fa-car" style="font-size: 3rem; opacity: 0.5; margin-bottom: 0.6rem; display: inline-block;"></i>
          <p>Enter a vehicle review above<br>and click <strong>Analyze Sentiment</strong></p>
        </div>
      </div>
    </div>
  </div>
  <footer>
    <i class="fas fa-robot"></i> AI-powered sentiment analysis (simulated core) — classifies positive, negative, neutral with confidence scores. Built for vehicle review insights.
  </footer>
</div>

<script>
  // ----------------------------------------------
  // ADVANCED SENTIMENT ANALYSIS ENGINE (Mock + Enhanced heuristic)
  // Real-world ready simulation with lexicon & basic ML-like scoring
  // Supports vehicle domain: car specific terms, adjectives, modifiers
  // ----------------------------------------------
  
  // Domain-specific sentiment lexicon (vehicles, driving experience)
  const sentimentLexicon = {
    // strong positive (weight = +2.0)
    strongPos: [
      'amazing', 'incredible', 'perfect', 'outstanding', 'exceptional', 'flawless', 'revolutionary', 
      'exhilarating', 'beast', 'game changer', 'love', 'awesome', 'brilliant', 'fantastic', 
      'superb', 'luxurious', 'state of the art', 'smooth', 'powerful', 'addictive'
    ],
    // moderate positive (weight +1.0)
    moderatePos: [
      'good', 'great', 'nice', 'clean', 'reliable', 'comfortable', 'efficient', 'solid', 
      'decent', 'pleasant', 'responsive', 'sharp', 'quiet', 'spacious', 'practical', 'value'
    ],
    // strong negative (weight -2.0)
    strongNeg: [
      'terrible', 'horrible', 'awful', 'disaster', 'nightmare', 'waste', 'regret', 'worst',
      'broken', 'garbage', 'useless', 'defective', 'dangerous', 'cheap junk'
    ],
    // moderate negative (weight -1.0)
    moderateNeg: [
      'bad', 'poor', 'weak', 'annoying', 'frustrating', 'laggy', 'cheap', 'disappointing',
      'mediocre', 'underpowered', 'noisy', 'rough', 'stiff', 'outdated', 'clunky'
    ],
    // intensifiers (boosts sentiment magnitude)
    intensifiers: ['very', 'extremely', 'absolutely', 'really', 'so', 'too', 'super', 'highly'],
    // negations (flip sentiment)
    negations: ['not', 'no', 'never', 'neither', 'nor', "isn't", "aren't", "wasn't", "weren't", "don't", "doesn't", "didn't"]
  };

  // Helper: preprocess text (lowercase, split into tokens)
  function tokenize(text) {
    return text.toLowerCase().match(/\b\w+(?:'\w+)?\b/g) || [];
  }

  // get n-grams for phrase detection (bigrams for keyphrases like "game changer")
  function getBigrams(tokens) {
    const bigrams = [];
    for (let i = 0; i < tokens.length - 1; i++) {
      bigrams.push(tokens[i] + ' ' + tokens[i+1]);
    }
    return bigrams;
  }

  // Advanced sentiment analysis returning sentiment label and confidence score (0-1) plus raw score
  function analyzeVehicleSentiment(reviewText) {
    if (!reviewText.trim()) {
      return { sentiment: 'neutral', confidence: 0.0, rawScore: 0, explanation: "Empty review." };
    }
    
    const originalLower = reviewText.toLowerCase();
    const tokens = tokenize(originalLower);
    const bigrams = getBigrams(tokens);
    
    let sentimentScore = 0;
    let totalWeight = 0;
    let flags = { hasNegation: false };
    
    // detect negation windows: mark positions
    let negatedIndex = new Array(tokens.length).fill(false);
    for (let i = 0; i < tokens.length; i++) {
      if (sentimentLexicon.negations.includes(tokens[i])) {
        flags.hasNegation = true;
        // mark next 3 tokens as negated (simple contextual)
        for (let j = i+1; j <= Math.min(i+3, tokens.length-1); j++) {
          negatedIndex[j] = true;
        }
      }
    }
    
    // helper to score word or bigram with optional negation flip
    function addScoreForTerm(term, weight, isNegated) {
      let finalWeight = weight;
      if (isNegated) finalWeight = -weight * 0.7;   // negation flips & reduces magnitude
      sentimentScore += finalWeight;
      totalWeight += Math.abs(finalWeight);
      return finalWeight;
    }
    
    // First check bigrams (catch 'game changer', 'state of the art')
    for (let bg of bigrams) {
      let found = false;
      let weight = 0;
      if (sentimentLexicon.strongPos.includes(bg)) { weight = 2.0; found=true; }
      else if (sentimentLexicon.moderatePos.includes(bg)) { weight = 1.0; found=true; }
      else if (sentimentLexicon.strongNeg.includes(bg)) { weight = -2.0; found=true; }
      else if (sentimentLexicon.moderateNeg.includes(bg)) { weight = -1.0; found=true; }
      if (found) {
        // approximate negation based on token presence before bigram (rough)
        let bigramNegated = false;
        const firstTokenOfBigram = bg.split(' ')[0];
        const idx = tokens.indexOf(firstTokenOfBigram);
        if (idx !== -1 && negatedIndex[idx]) bigramNegated = true;
        addScoreForTerm(bg, weight, bigramNegated);
      }
    }
    
    // Then single tokens (skip if part of already bigram? simpler just add but avoid double counting? let's unify: we'll add but low weight)
    // but to avoid overcount we just reduce weight nuance: okay
    for (let i = 0; i < tokens.length; i++) {
      const word = tokens[i];
      let weight = 0;
      let matched = false;
      if (sentimentLexicon.strongPos.includes(word)) { weight = 1.8; matched=true; }
      else if (sentimentLexicon.moderatePos.includes(word)) { weight = 0.9; matched=true; }
      else if (sentimentLexicon.strongNeg.includes(word)) { weight = -1.8; matched=true; }
      else if (sentimentLexicon.moderateNeg.includes(word)) { weight = -0.9; matched=true; }
      
      if (matched) {
        const isNegated = negatedIndex[i];
        addScoreForTerm(word, weight, isNegated);
      }
    }
    
    // intensifier boost: look for intensifier before positive/negative words
    for (let i = 0; i < tokens.length - 1; i++) {
      if (sentimentLexicon.intensifiers.includes(tokens[i])) {
        const nextWord = tokens[i+1];
        let nextWeight = 0;
        let nextIsPos = false;
        if (sentimentLexicon.strongPos.includes(nextWord) || sentimentLexicon.moderatePos.includes(nextWord)) {
          nextWeight = 0.7;
          nextIsPos = true;
        } else if (sentimentLexicon.strongNeg.includes(nextWord) || sentimentLexicon.moderateNeg.includes(nextWord)) {
          nextWeight = -0.7;
          nextIsPos = false;
        }
        if (nextWeight !== 0) {
          sentimentScore += nextWeight * 0.6; // extra boost
          totalWeight += Math.abs(nextWeight * 0.6);
        }
      }
    }
    
    // Additional vehicle specific keyword modifiers: "fuel economy" neutral positive ?
    if (originalLower.includes('fuel economy') && sentimentScore < 0.2) sentimentScore += 0.3;
    if (originalLower.includes('safety') || originalLower.includes('reliable')) sentimentScore += 0.4;
    if (originalLower.includes('issue') || originalLower.includes('recall')) sentimentScore -= 0.5;
    if (originalLower.includes('expensive')) sentimentScore -= 0.4;
    if (originalLower.includes('worth every penny')) sentimentScore += 0.8;
    
    // Normalize score: softmax style confidence between 0-1
    let rawScore = sentimentScore;
    // clamp rawscore between -4 and 4
    let cappedScore = Math.min(4, Math.max(-4, rawScore));
    let confidence = 0;
    // map from [-4,4] -> [0,1] using sigmoid-style but linear mapping with base
    if (cappedScore >= 0) {
      confidence = Math.min(0.98, 0.5 + (cappedScore / 5.5));
    } else {
      confidence = Math.min(0.98, 0.5 + (cappedScore / 5.5)); // cappedScore negative reduces confidence
    }
    confidence = Math.max(0.12, Math.min(0.98, confidence));
    
    let sentimentLabel = 'neutral';
    if (rawScore > 0.55) sentimentLabel = 'positive';
    else if (rawScore < -0.45) sentimentLabel = 'negative';
    else sentimentLabel = 'neutral';
    
    // special edge: confidence high if extreme
    if (rawScore >= 1.8) sentimentLabel = 'positive';
    if (rawScore <= -1.6) sentimentLabel = 'negative';
    
    // confidence rounding
    confidence = Math.round(confidence * 100) / 100;
    
    // additional readability
    return {
      sentiment: sentimentLabel,
      confidence: confidence,
      rawScore: rawScore,
      normalizedScore: (rawScore + 4) / 8, // 0-1 scaled
      explanation: `Sentiment polarity: ${rawScore > 0 ? 'positive' : rawScore < 0 ? 'negative' : 'neutral'} drive score.`
    };
  }
  
  // DOM elements
  const reviewInput = document.getElementById('reviewText');
  const analyzeBtn = document.getElementById('analyzeBtn');
  const clearBtn = document.getElementById('clearBtn');
  const resultArea = document.getElementById('resultArea');
  const charCounterSpan = document.getElementById('charCount');
  
  // update character count
  function updateCharCount() {
    charCounterSpan.innerText = reviewInput.value.length;
  }
  
  reviewInput.addEventListener('input', updateCharCount);
  updateCharCount();
  
  // function to render results with beautiful UI
  function renderSentimentResult(reviewText, analysis) {
    const { sentiment, confidence, rawScore, normalizedScore, explanation } = analysis;
    // sentiment icon & colors
    let badgeIcon = '', badgeText = '', badgeColor = '', fillClass = '';
    if (sentiment === 'positive') {
      badgeIcon = '<i class="fas fa-smile-wink"></i>';
      badgeText = 'POSITIVE';
      badgeColor = '#22c55e';
      fillClass = 'positive-fill';
    } else if (sentiment === 'negative') {
      badgeIcon = '<i class="fas fa-frown"></i>';
      badgeText = 'NEGATIVE';
      badgeColor = '#ef4444';
      fillClass = 'negative-fill';
    } else {
      badgeIcon = '<i class="fas fa-meh"></i>';
      badgeText = 'NEUTRAL';
      badgeColor = '#eab308';
      fillClass = 'neutral-fill';
    }
    
    const percentConfidence = Math.round(confidence * 100);
    const scorePercent = Math.min(100, Math.max(0, Math.round((rawScore + 3) / 6 * 100))); // aesthetic meter
    const fillWidth = `${Math.min(100, Math.max(0, (rawScore + 2.5) / 5 * 100))}%`;
    
    // confidence bar uses confidence directly
    const confidencePercent = percentConfidence;
    
    const resultHtml = `
      <div style="animation: fadeInUp 0.3s ease;">
        <div class="sentiment-badge" style="background: ${badgeColor}10; border-left: 5px solid ${badgeColor};">
          <span style="font-size: 2rem;">${badgeIcon}</span>
          <span style="font-weight: 800; letter-spacing: 1px; color: ${badgeColor};">${badgeText}</span>
          <span style="margin-left: auto; background: white; border-radius: 40px; padding: 0.2rem 0.8rem; font-size:0.8rem;">${percentConfidence}% confidence</span>
        </div>
        
        <div style="margin-top: 1rem;">
          <div style="display: flex; justify-content: space-between;"><span>Sentiment intensity</span><span>${sentiment === 'positive' ? '▲' : sentiment === 'negative' ? '▼' : '●'} ${rawScore.toFixed(2)}</span></div>
          <div class="score-bar-container">
            <div class="score-fill ${fillClass}" style="width: ${fillWidth};"></div>
          </div>
        </div>
        
        <div class="metrics">
          <div class="metric-item"><span><i class="fas fa-chart-simple"></i> Raw polarity score</span><span class="confidence-highlight">${rawScore > 0 ? '+' : ''}${rawScore.toFixed(2)}</span></div>
          <div class="metric-item"><span><i class="fas fa-percent"></i> AI Confidence</span><span>${confidencePercent}%</span></div>
          <div class="metric-item"><span><i class="fas fa-car"></i> Vehicle context</span><span>${explanation}</span></div>
        </div>
        
        <div class="review-text-analysis">
          <i class="fas fa-quote-left" style="margin-right: 6px; opacity:0.6;"></i> 
          "${reviewText.length > 180 ? reviewText.substring(0,180)+'...' : reviewText}"
        </div>
        
        <div style="margin-top: 1.2rem; background: #eef3ff; border-radius: 1rem; padding: 0.6rem 1rem; font-size:0.75rem;">
          <i class="fas fa-microchip"></i> <strong>AutoSentinel AI</strong> — Domain-trained lexicon + dynamic negation handling for automotive reviews.
        </div>
      </div>
    `;
    
    resultArea.innerHTML = resultHtml;
  }
  
  function showLoading() {
    resultArea.innerHTML = `
      <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2.5rem;">
        <div class="loader" style="border-top-color: #256f8f; border-width: 4px; width: 40px; height: 40px;"></div>
        <p style="margin-top: 1rem; font-weight:500;">Scanning vehicle sentiment...</p>
      </div>
    `;
  }
  
  function performAnalysis() {
    const rawReview = reviewInput.value.trim();
    if (!rawReview) {
      resultArea.innerHTML = `
        <div style="text-align: center; padding: 1.8rem; background: #fff6e5; border-radius: 1.5rem;">
          <i class="fas fa-exclamation-triangle" style="font-size: 2rem; color:#e07c3c;"></i>
          <p style="margin-top: 0.6rem;">Please enter a vehicle review before analyzing.</p>
        </div>
      `;
      return;
    }
    
    showLoading();
    // simulate realistic tiny delay to mimic model inference
    setTimeout(() => {
      const analysis = analyzeVehicleSentiment(rawReview);
      renderSentimentResult(rawReview, analysis);
    }, 180);
  }
  
  function clearAll() {
    reviewInput.value = '';
    updateCharCount();
    resultArea.innerHTML = `
      <div style="text-align: center; padding: 1rem 0 2rem 0; color: #5e7e9e;">
        <i class="fas fa-car" style="font-size: 3rem; opacity: 0.5; margin-bottom: 0.6rem; display: inline-block;"></i>
        <p>Enter a vehicle review above<br>and click <strong>Analyze Sentiment</strong></p>
      </div>
    `;
    reviewInput.focus();
  }
  
  // event listeners
  analyzeBtn.addEventListener('click', performAnalysis);
  clearBtn.addEventListener('click', clearAll);
  
  // example chip fill
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const exampleText = chip.getAttribute('data-example');
      if (exampleText) {
        reviewInput.value = exampleText;
        updateCharCount();
        performAnalysis(); // Auto analyze on example click
      }
    });
  });
  
  // optional: ctrl+enter shortcut
  reviewInput.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
      e.preventDefault();
      performAnalysis();
    }
  });
  
  // initial placeholder + subtle style
  const style = document.createElement('style');
  style.textContent = `
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(10px);}
      to { opacity: 1; transform: translateY(0);}
    }
  `;
  document.head.appendChild(style);
</script>
</body>
</html>
